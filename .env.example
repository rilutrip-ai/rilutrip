# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Internal API Gateway Secret
# Used to secure calls between Next.js API routes and Supabase Edge Functions
API_GATEWAY_SECRET=your_api_gateway_secret

# Map Provider Configuration
# Choose which map provider to use: 'google' or 'mapbox'
# Default: 'google' (if not specified)
NEXT_PUBLIC_MAP_PROVIDER=google

# Google Maps API Key (domain-restricted, exposed to frontend)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=your_map_id

# Mapbox API Key (optional, only needed if using Mapbox)
NEXT_PUBLIC_MAPBOX_API_KEY=your_mapbox_token

# Gemini API Key (stored in Supabase Edge Function environment, NOT here)
# This is configured in Supabase dashboard under Edge Functions secrets

# Yjs WebSocket Server
NEXT_PUBLIC_YJS_SERVER_URL=wss://yjs.example.com

# Upstash Redis (used for rate limiting /api/resolve-places)
# Create a free Redis at https://console.upstash.com and copy the REST credentials
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token
